        <mxCell id="ts7" value="&lt;b&gt;OR&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="426" y="250" width="45" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="ts8" value="&lt;b&gt;P6&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#388e3c;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="479" y="250" width="45" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="ts9" value="&lt;b&gt;OR&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="532" y="250" width="45" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="ts10" value="&lt;b&gt;NOT&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#f44336;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="585" y="250" width="45" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="ts11" value="&lt;b&gt;AND&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#2196f3;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="638" y="250" width="45" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="ts12" value="&lt;b&gt;OR&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="691" y="250" width="45" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="ts13" value="&lt;b&gt;AND&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#2196f3;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="744" y="250" width="45" height="35" as="geometry"/>
        </mxCell>

        <!-- Processing pointer -->
        <mxCell id="pointer" value="▼" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontColor=#f44336;" vertex="1" parent="1">
          <mxGeometry x="55" y="295" width="45" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="pointer_label" value="&lt;font color=&quot;#f44336&quot;&gt;&lt;b&gt;current&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="320" width="55" height="20" as="geometry"/>
        </mxCell>

        <!-- Processing direction -->
        <mxCell id="process_arrow" value="" style="shape=flexArrow;endArrow=classic;html=1;strokeWidth=1;fillColor=#4caf50;strokeColor=#4caf50;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="110" y="345" as="sourcePoint"/>
            <mxPoint x="790" y="345" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="process_label" value="&lt;b&gt;Process left to right&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#4caf50;" vertex="1" parent="1">
          <mxGeometry x="390" y="350" width="120" height="20" as="geometry"/>
        </mxCell>

        <!-- Evaluation Stack -->
        <mxCell id="eval_stack_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="920" y="200" width="250" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="eval_stack_title" value="&lt;b&gt;Evaluation Stack&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="970" y="210" width="150" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="eval_stack_label" value="&lt;font style=&quot;font-size:10px&quot;&gt;(initially empty)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#999;" vertex="1" parent="1">
          <mxGeometry x="970" y="235" width="150" height="20" as="geometry"/>
        </mxCell>

        <!-- Stack visualization (vertical) -->
        <mxCell id="stack_frame" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="990" y="265" width="110" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="stack_bottom" value="&lt;font color=&quot;#999&quot;&gt;bottom&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="990" y="345" width="110" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="stack_top_arrow" value="← top" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#4caf50;" vertex="1" parent="1">
          <mxGeometry x="1105" y="265" width="50" height="20" as="geometry"/>
        </mxCell>

        <!-- Algorithm rules box -->
        <mxCell id="rules_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999;arcSize=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="540" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="rules_title" value="&lt;b&gt;Algorithm Rules&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="55" y="430" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="rule1_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#388e3c;" vertex="1" parent="1">
          <mxGeometry x="55" y="465" width="20" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="rule1_text" value="&lt;b&gt;PREDICATE&lt;/b&gt;: Look up predicate by index → evaluate → push result (TRUE/FALSE)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="85" y="460" width="470" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="rule2_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#2196f3;" vertex="1" parent="1">
          <mxGeometry x="55" y="500" width="20" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="rule2_text" value="&lt;b&gt;AND&lt;/b&gt;: Pop 2 values. If first is FALSE → push FALSE (short-circuit).&lt;br&gt;        Otherwise: evaluate second, push (first AND second)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="85" y="495" width="480" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="rule3_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;" vertex="1" parent="1">
          <mxGeometry x="55" y="545" width="20" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="rule3_text" value="&lt;b&gt;OR&lt;/b&gt;: Pop 2 values. If first is TRUE → push TRUE (short-circuit).&lt;br&gt;       Otherwise: evaluate second, push (first OR second)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="85" y="540" width="480" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="rule4_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#f44336;" vertex="1" parent="1">
          <mxGeometry x="55" y="590" width="20" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="rule4_text" value="&lt;b&gt;NOT&lt;/b&gt;: Pop 1 value → push negation" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="85" y="585" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="rule5_text" value="&lt;b&gt;After all tokens processed:&lt;/b&gt; Stack has exactly 1 value = final result" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="55" y="620" width="460" height="25" as="geometry"/>
        </mxCell>

        <!-- Predicate lookup box -->
        <mxCell id="lookup_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999;arcSize=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="420" width="570" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="lookup_title" value="&lt;b&gt;Predicate Lookup (when token is PREDICATE)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="615" y="430" width="350" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="lookup_flow" value="&lt;font face=&quot;monospace&quot; style=&quot;font-size:11px&quot;&gt;1. Read predicate_idx from token&lt;br&gt;&lt;br&gt;2. Lookup: pred = predicates_map[predicate_idx]&lt;br&gt;&lt;br&gt;3. Dispatch based on pred.comparison_type:&lt;br&gt;   • EXACT_MATCH  → byte-by-byte compare&lt;br&gt;   • STARTS_WITH  → compare first N bytes&lt;br&gt;   • ENDS_WITH    → compare last N bytes&lt;br&gt;   • CONTAINS     → run KMP DFA&lt;br&gt;   • ABOVE/BELOW  → numeric comparison&lt;br&gt;&lt;br&gt;4. Push result (TRUE or FALSE) onto stack&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="615" y="460" width="540" height="180" as="geometry"/>
        </mxCell>

        <!-- Short-circuit highlight -->
        <mxCell id="shortcircuit_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#f44336;arcSize=10;dashed=1;dashPattern=5 3;" vertex="1" parent="1">
          <mxGeometry x="1200" y="80" width="350" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="shortcircuit_title" value="&lt;b&gt;⚡ Short-Circuit Evaluation&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#f44336;" vertex="1" parent="1">
          <mxGeometry x="1220" y="90" width="310" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="shortcircuit_text" value="&lt;font style=&quot;font-size:10px&quot;&gt;AND: If first operand is FALSE, skip second operand&lt;br&gt;OR: If first operand is TRUE, skip second operand&lt;br&gt;&lt;br&gt;Critical performance optimization for rule evaluation&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="1220" y="115" width="310" height="50" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
