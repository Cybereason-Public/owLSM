        </mxCell>
        <mxCell id="algo_desc" value="&lt;font style=&quot;font-size:11px&quot;&gt;O(n) time complexity • Fixed stack size • No recursion&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="55" y="125" width="320" height="25" as="geometry"/>
