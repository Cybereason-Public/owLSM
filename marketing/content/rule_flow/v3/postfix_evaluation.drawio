        <mxCell id="algo_title" value="&lt;b&gt;Postfix Evaluation Algorithm&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(Reverse Polish Notation Evaluation)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#333;" vertex="1" parent="1">
