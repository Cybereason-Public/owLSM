<mxfile host="app.diagrams.net" modified="2026-03-16" agent="owLSM" version="24.0" type="device">
  <diagram id="rule-to-ast" name="Rule to AST">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Diagram 1: Sigma Rule → AST&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="700" y="20" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- Left side: Sigma Rule -->
        <mxCell id="rule_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="420" height="480" as="geometry"/>
        </mxCell>
        <mxCell id="rule_title" value="&lt;b&gt;Sigma Rule (condition)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="140" y="110" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="rule_code" value="&lt;font face=&quot;monospace&quot; style=&quot;font-size:11px&quot;&gt;condition:&lt;br&gt;  selection_passwd and (&lt;br&gt;    selection_suspicious_binaries or (&lt;br&gt;      selection_suspicious_uid and&lt;br&gt;      not filter_whitelisted_binaries&lt;br&gt;    )&lt;br&gt;  )&lt;br&gt;&lt;br&gt;where:&lt;br&gt;&lt;br&gt;selection_passwd:&lt;br&gt;  target.file.path|contains: &quot;/etc/passwd&quot;&lt;br&gt;&lt;br&gt;selection_suspicious_binaries:&lt;br&gt;  process.file.path|endswith:&lt;br&gt;    - &quot;ash&quot;&lt;br&gt;    - &quot;echo&quot;&lt;br&gt;&lt;br&gt;selection_suspicious_uid:&lt;br&gt;  process.euid|above: 0&lt;br&gt;&lt;br&gt;filter_whitelisted_binaries:&lt;br&gt;  process.file.path|startswith:&lt;br&gt;    - &quot;/usr/bin/apt&quot;&lt;br&gt;    - &quot;/usr/bin/yum&quot;&lt;br&gt;    - &quot;/usr/sbin/useradd&quot;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="55" y="150" width="390" height="410" as="geometry"/>
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow1" value="" style="shape=flexArrow;endArrow=classic;html=1;strokeWidth=2;fillColor=#666;strokeColor=#666;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="480" y="340" as="sourcePoint"/>
            <mxPoint x="560" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow_label" value="&lt;b&gt;pySigma&lt;br&gt;Backend&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="475" y="285" width="70" height="40" as="geometry"/>
        </mxCell>

        <!-- Right side: AST -->
        <mxCell id="ast_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;arcSize=5;" vertex="1" parent="1">
