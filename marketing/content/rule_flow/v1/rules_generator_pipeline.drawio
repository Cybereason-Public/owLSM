<mxfile host="app.diagrams.net" modified="2026-03-16" agent="owLSM" version="24.0" type="device">
  <diagram id="rules-generator-pipeline" name="Rules Generator Pipeline">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Rules Generator Pipeline: YAML → JSON&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- YAML Input -->
        <mxCell id="yaml" value="&lt;b&gt;YAML Rule File&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id: 100&lt;br&gt;action: BLOCK_EVENT&lt;br&gt;events: [READ]&lt;br&gt;detection:&lt;br&gt;  selection_ssh_keys:&lt;br&gt;    target.file.path|contains:&lt;br&gt;      - &quot;.ssh/id_rsa&quot;&lt;br&gt;  condition: selection_ssh_keys and ...&lt;/font&gt;" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="240" height="170" as="geometry"/>
        </mxCell>

        <!-- Arrow 1 -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#666;" edge="1" source="yaml" target="validate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 1: Validate -->
        <mxCell id="validate" value="&lt;b&gt;Step 1&lt;/b&gt;&lt;br&gt;Schema&lt;br&gt;Validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="340" y="140" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="validate_desc" value="&lt;font style=&quot;font-size:9px&quot;&gt;• Required fields&lt;br&gt;• Field-event compatibility&lt;br&gt;• Modifier validity&lt;br&gt;• Value types &amp; ranges&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="330" y="225" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrow 2 -->
        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#666;" edge="1" source="validate" target="ast" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 2: AST -->
        <mxCell id="ast" value="&lt;b&gt;Step 2&lt;/b&gt;&lt;br&gt;pySigma&lt;br&gt;AST Parsing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="520" y="140" width="120" height="80" as="geometry"/>
        </mxCell>

        <!-- Tables branching from AST -->
        <mxCell id="arrow_tables" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=2;strokeColor=#666;" edge="1" source="ast" target="tables" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Lookup Tables -->
        <mxCell id="tables" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;arcSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="320" width="420" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="tables_title" value="&lt;b&gt;Deduplicated Lookup Tables&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="470" y="325" width="220" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="str_table" value="&lt;b&gt;id_to_string&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;0: &quot;.ssh/id_rsa&quot; (contains)&lt;br&gt;1: &quot;.ssh/id_ed25519&quot; (contains)&lt;br&gt;2: &quot;curl&quot;&lt;br&gt;3: &quot;wget&quot;&lt;br&gt;...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="380" y="355" width="185" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="pred_table" value="&lt;b&gt;id_to_predicate&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;0: file.path CONTAINS str[0]&lt;br&gt;1: file.path CONTAINS str[1]&lt;br&gt;2: filename ENDS_WITH str[2]&lt;br&gt;3: filename ENDS_WITH str[3]&lt;br&gt;...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="580" y="355" width="195" height="110" as="geometry"/>
        </mxCell>

        <!-- Arrow 3 -->
        <mxCell id="arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#666;" edge="1" source="ast" target="postfix" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 3: Postfix -->
        <mxCell id="postfix" value="&lt;b&gt;Step 3&lt;/b&gt;&lt;br&gt;Infix → Postfix&lt;br&gt;(RPN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="700" y="140" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="postfix_desc" value="&lt;font style=&quot;font-size:9px;&quot;&gt;P0 P1 OR P2 P3 OR AND&lt;br&gt;P4 P5 OR NOT AND&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#555;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="685" y="225" width="150" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrow 4 -->
        <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#666;" edge="1" source="postfix" target="tokens" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 4: Tokenize -->
        <mxCell id="tokens" value="&lt;b&gt;Step 4&lt;/b&gt;&lt;br&gt;Tokenize &amp;&lt;br&gt;Serialize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="880" y="140" width="120" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrow 5 -->
        <mxCell id="arrow5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#666;" edge="1" source="tokens" target="json" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- JSON Output -->
        <mxCell id="json" value="&lt;b&gt;JSON Output&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;{&lt;br&gt;  &quot;id_to_string&quot;: {...},&lt;br&gt;  &quot;id_to_predicate&quot;: {...},&lt;br&gt;  &quot;id_to_ip&quot;: {...},&lt;br&gt;  &quot;rules&quot;: [{&lt;br&gt;    &quot;tokens&quot;: [...]&lt;br&gt;  }]&lt;br&gt;}&lt;/font&gt;" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="100" width="200" height="170" as="geometry"/>
        </mxCell>

        <!-- Bottom annotation -->
        <mxCell id="note" value="&lt;i&gt;pySigma handles modifier expansion (contains → wildcards), selection AND/OR logic, and condition parsing.&lt;br&gt;The custom OwlsmBackend builds predicates and expression trees instead of query strings.&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#777;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="340" y="510" width="550" height="40" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
